{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^package\\.json$"],
      "matchStrings": [
        "\"(?<depName>@opentelemetry/[^\"]+)\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "open-telemetry/opentelemetry-js",
      "extractVersionTemplate": "^experimental/v?(?<version>.+)$"
    }
  ]
}
