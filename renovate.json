{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prHourlyLimit": 30,
  "configMigration": true,
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "matchPackageNames": [
        "@opentelemetry/api"
      ],
      "changelogUrl": "https://github.com/open-telemetry/opentelemetry-js/releases/tag/api%2Fv{{newVersion}}error"
    }
  ]
}
