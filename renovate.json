{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prHourlyLimit": 30,
  "configMigration": true,
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "matchPackageNames": [
        "@opentelemetry/api-logs"
      ],
      "sourceUrl": "https://github.com/open-telemetry/opentelemetry-js/blob/main/experimental",
      "changelogUrl": "https://github.com/open-telemetry/opentelemetry-js/blob/main/experimental/CHANGELOG.md"
    }
  ]
}
